  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6E6E6E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other.special-method",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#00AAFF"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#B2A69A"
      }
    },
    {
      "name": "Keyword Unit",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#DA5538"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D8D0CA"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#10D00D"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#6E6E6E"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#DA5538"
      }
    },
    {
      "name": "Numeric",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#DA5538"
      }
    },
    {
      "name": "Constant Color",
      "scope": [
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#00AAFF"
      }
    },
    {
      "name": "Constant Symbol",
      "scope": [
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#B2A69A"
      }
    },
    {
      "name": "Variable Interpolation",
      "scope": [
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#9D9189"
      }
    },
    {
      "name": "Function Name",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function.any-method"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Support Function",
      "scope": [
        "support.function"
      ],
      "settings": {
        "foreground": "#00AAFF"
      }
    },
    {
      "name": "Class / Type Name",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.type.class",
        "support.class",
        "meta.class"
      ],
      "settings": {
        "foreground": "#E0694F"
      }
    },
    {
      "name": "Type Name (underline)",
      "scope": [
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#E0694F",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Inherited Class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Section",
      "scope": [
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#cc6666",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#DA5538"
      }
    },
    {
      "name": "Tag Attribute ID",
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.id punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "meta.selector",
        "meta.selector entity",
        "meta.selector entity punctuation"
      ],
      "settings": {
        "foreground": "#b294bb"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#B2A69A"
      }
    },
    {
      "name": "Invalid / Illegal",
      "scope": [
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#28211C",
        "background": "#cc6666"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#B2A69A"
      }
    },
    {
      "name": "Punctuation String Definition",
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.variable",
        "punctuation.definition.parameters",
        "punctuation.definition.array"
      ],
      "settings": {
        "foreground": "#10D00D"
      }
    },
    {
      "name": "Punctuation Heading / Identity",
      "scope": [
        "punctuation.definition.heading",
        "punctuation.definition.identity"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Punctuation Bold",
      "scope": [
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#E0694F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Punctuation Italic",
      "scope": [
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#b294bb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Embedded Section Punctuation",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#BF3333"
      }
    },
    {
      "name": "Markup Bold",
      "scope": [
        "markup.bold",
        "markup.bold string"
      ],
      "settings": {
        "foreground": "#DA5538",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": [
        "markup.italic",
        "markup.italic string"
      ],
      "settings": {
        "foreground": "#b294bb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Heading",
      "scope": [
        "markup.heading",
        "markup.heading punctuation.definition.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Markup Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#cc6666"
      }
    },
    {
      "name": "Markup Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#b294bb"
      }
    },
    {
      "name": "Markup Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#DA5538"
      }
    },
    {
      "name": "Markup Raw / Inline Code",
      "scope": [
        "markup.raw.inline",
        "markup.raw.block",
        "text.literal"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Markup List",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item"
      ],
      "settings": {
        "foreground": "#cc6666"
      }
    },
    {
      "name": "GFM Heading",
      "scope": [
        "source.gfm markup.heading"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Link Text",
      "scope": [
        "string.other.link",
        "punctuation.definition.string.begin.markdown",
        "punctuation.definition.string.end.markdown"
      ],
      "settings": {
        "foreground": "#10D00D"
      }
    },
    {
      "name": "Link URL",
      "scope": [
        "markup.underline.link",
        "markup.underline.link.image"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "underline"
      }
    }
  ]
}
